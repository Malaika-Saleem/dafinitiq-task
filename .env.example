# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=sqlite:///./voice_agent.db

# JWT
JWT_SECRET='YOUR_JWT_SECRET_HERE'
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=3600

# Deepgram (STT) - optional
DEEPGRAM_API_KEY=''

# ElevenLabs (TTS) - optional
ELEVENLABS_API_KEY=''

# Groq (alternative LLM) - optional
GROQ_API_KEY=''
GROQ_API_URL=https://api.groq.com/openai/v1

# Select LLM provider: 'gemini' or 'groq'
LLM_PROVIDER=groq